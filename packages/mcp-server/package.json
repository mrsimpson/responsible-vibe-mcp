{
  "name": "@codemcp/workflows-server",
  "version": "5.3.0",
  "description": "Lightweight MCP server for responsible-vibe development workflows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ade-workflows-server": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "skill/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean:build": "rimraf ./dist",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@codemcp/workflows-core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.25.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
